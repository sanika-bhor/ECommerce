@model List<ECommerceApplication.Models.Categories>
@{
    ViewData["Title"] = "Manage Categories";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Categories</h2>
        <a class="btn btn-primary" asp-action="Create">Add Category</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th style="width:120px;">ID</th>
                        <th>Name</th>
                        <th class="text-end" style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.CategoryId</td>
                        <td class="fw-semibold">@c.CategoryName</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.CategoryId">Edit</a>
                            <form asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete category #@c.CategoryId?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

