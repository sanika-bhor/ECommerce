@model List<ECommerceApplication.Models.Subcategory>
@{
    ViewData["Title"] = "Manage Subcategories";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Subcategories</h2>
        <a class="btn btn-primary" asp-action="Create">Add Subcategory</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;">ID</th>
                        <th>Subcategory</th>
                        <th>Category</th>
                        <th class="text-end">Products</th>
                        <th class="text-end" style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td class="fw-semibold">@s.Name</td>
                        <td>@s.CategoryName</td>
                        <td class="text-end">@s.ProductsCount</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@s.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete subcategory #@s.Id?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

