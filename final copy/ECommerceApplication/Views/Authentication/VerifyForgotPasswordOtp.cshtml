@model string

@{
    ViewData["Title"] = "Verify OTP";
}

<div class="container" style="max-width: 560px; margin-top: 24px;">
    <h2 style="margin-bottom: 6px;">Verify OTP</h2>
    <p class="text-muted" style="margin-bottom: 18px;">
        We sent a 6-digit OTP to <strong>@Model</strong>. Enter it below to reset your password.
    </p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/Authentication/VerifyForgotPasswordOtp">
        <div class="mb-3">
            <label class="form-label" for="otp">OTP</label>
            <input class="form-control" type="text" id="otp" name="otp" inputmode="numeric" pattern="[0-9]{6}" required />
            <div class="form-text">OTP is valid for a few minutes.</div>
        </div>

        <button class="btn btn-primary w-100" type="submit">
            Verify &amp; Continue
        </button>
    </form>

    <div class="mt-3 text-center">
        <form method="post" action="/Authentication/ResendForgotPasswordOtp" style="display: inline;">
            <button class="btn btn-link" type="submit">Resend OTP</button>
        </form>
    </div>

    <div class="mt-3">
        <a href="/Authentication/ForgotPassword">Back</a>
    </div>
</div>

