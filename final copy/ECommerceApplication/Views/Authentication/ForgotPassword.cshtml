@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container" style="max-width: 560px; margin-top: 24px;">
    <h2 style="margin-bottom: 6px;">Forgot Password</h2>
    <p class="text-muted" style="margin-bottom: 18px;">
        Enter your email and we will send an OTP to reset your password.
    </p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/Authentication/ForgotPassword">
        <div class="mb-3">
            <label class="form-label" for="email">Email</label>
            <input class="form-control" type="email" id="email" name="email" required />
        </div>

        <button class="btn btn-primary w-100" type="submit">
            Send OTP
        </button>
    </form>

    <div class="mt-3">
        <a href="/Authentication/Login">Back to Login</a>
    </div>
</div>

