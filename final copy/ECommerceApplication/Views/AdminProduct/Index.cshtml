@model ECommerceApplication.ViewModels.AdminProductIndexViewModel
@{
    ViewData["Title"] = "Manage Products";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Products</h2>
        <a class="btn btn-primary" asp-action="Create">Add Product</a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label mb-1">Search</label>
                    <input class="form-control" name="search" value="@Model.Search" placeholder="Product name..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label mb-1">Category</label>
                    <select class="form-select" name="categoryId" asp-items="Model.Categories"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Min Price</label>
                    <input class="form-control" name="minPrice" value="@(Model.MinPrice?.ToString() ?? "")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Max Price</label>
                    <input class="form-control" name="maxPrice" value="@(Model.MaxPrice?.ToString() ?? "")" />
                </div>
                <div class="col-md-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="inStockOnly" name="inStockOnly" value="true" @(Model.InStockOnly ? "checked" : "") />
                        <label class="form-check-label" for="inStockOnly">In stock</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Filter</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;">Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Stock</th>
                        <th class="text-end" style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Products)
                {
                    bool lowStock = p.Quantity < Model.LowStockThreshold;
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(p.Image))
                            {
                                <img src="@p.Image" alt="@p.ProductTitle" style="width:72px;height:72px;object-fit:cover;border-radius:10px;" />
                            }
                            else
                            {
                                <div class="text-muted small">No image</div>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@p.ProductTitle</div>
                            <div class="text-muted small">ID: @p.ProductId</div>
                        </td>
                        <td>
                            <div>@(string.IsNullOrWhiteSpace(p.CategoryName) ? "-" : p.CategoryName)</div>
                            @if (!string.IsNullOrWhiteSpace(p.SubCategoryName))
                            {
                                <div class="text-muted small">@p.SubCategoryName</div>
                            }
                        </td>
                        <td class="text-end">₹@p.UnitPrice.ToString("0.00")</td>
                        <td class="text-end">
                            <span class="@(lowStock ? "text-danger fw-bold" : "")">@p.Quantity</span>
                            @if (lowStock)
                            {
                                <span class="badge bg-danger ms-2">Low Stock</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.ProductId">Edit</a>
                            <form asp-action="Delete" asp-route-id="@p.ProductId" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete product #@p.ProductId?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

