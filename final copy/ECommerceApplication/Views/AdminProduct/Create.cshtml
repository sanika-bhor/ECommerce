@model ECommerceApplication.ViewModels.AdminProductEditViewModel
@{
    ViewData["Title"] = "Add Product";
    var categories = ViewBag.Categories as IEnumerable<ECommerceApplication.Repository.Interfaces.IdNameOption>
        ?? Enumerable.Empty<ECommerceApplication.Repository.Interfaces.IdNameOption>();
    var subcategories = ViewBag.Subcategories as IEnumerable<ECommerceApplication.Repository.Interfaces.IdNameOption>
        ?? Enumerable.Empty<ECommerceApplication.Repository.Interfaces.IdNameOption>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Add Product</h2>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input asp-for="ProductTitle" class="form-control" />
                        <span class="text-danger" asp-validation-for="ProductTitle"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Price</label>
                        <input asp-for="UnitPrice" class="form-control" />
                        <span class="text-danger" asp-validation-for="UnitPrice"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Stock</label>
                        <input asp-for="Quantity" class="form-control" />
                        <span class="text-danger" asp-validation-for="Quantity"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Category</label>
                        <select id="categorySelect" asp-for="CategoryId" class="form-select">
                            <option value="">Select category</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Subcategory</label>
                        <select id="subCategorySelect" asp-for="SubcategoryId" class="form-select">
                            <option value="">Select subcategory</option>
                            @foreach (var s in subcategories)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="SubcategoryId"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Image</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const categorySelect = document.getElementById('categorySelect');
            const subSelect = document.getElementById('subCategorySelect');

            async function refreshSubcategories(categoryId) {
                subSelect.innerHTML = '<option value="">Select subcategory</option>';
                if (!categoryId) return;
                const url = `/AdminProduct/GetSubcategoriesByCategory?categoryId=${encodeURIComponent(categoryId)}`;
                const res = await fetch(url);
                if (!res.ok) return;
                const data = await res.json();
                for (const s of data) {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = s.name;
                    subSelect.appendChild(opt);
                }
            }

            categorySelect?.addEventListener('change', function () {
                refreshSubcategories(this.value);
            });
        })();
    </script>
}

