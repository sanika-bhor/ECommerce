@{
    ViewData["Title"] = "About Us";
}
<link rel="stylesheet" href="~/css/info-pages.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4">About ShopSmart</h2>
    <p class="lead text-muted text-center">Making online shopping smarter, simpler, and faster.</p>
    <div class="row mt-4">
        <div class="col-md-6">
            <p>
                ShopSmart is a modern eCommerce platform built with a passion for quality and convenience. 
                We provide a wide range of products including fashion, electronics, home decor, and more — 
                all from the comfort of your home.
            </p>
            <p>
                Our mission is to bring the best products to your doorstep with excellent customer support 
                and a seamless shopping experience. We are constantly evolving with technology and trends 
                to serve you better.
            </p>
        </div>
        <div class="col-md-6">
            <img src="~/images/about_us.jpeg" class="img-fluid rounded shadow" alt="About ShopSmart">
        </div>
    </div>
</div>
