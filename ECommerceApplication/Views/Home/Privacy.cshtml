@{
    ViewData["Title"] = "Privacy Policy";
}
<link rel="stylesheet" href="~/css/info-pages.css" />
<script src="~/js/contact.js" asp-append-version="true"></script> <!-- Reuse scroll animation -->

<div class="container mt-5 animate-fade">
    <h2 class="text-center mb-4">Privacy Policy</h2>
    
    <p>
        At <strong>ShopSmart</strong>, we value your privacy and are committed to protecting your personal information. 
        This Privacy Policy outlines how we collect, use, and safeguard your data when you visit or make a purchase from our website.
    </p>

    <h5 class="mt-4">1. Information We Collect</h5>
    <ul>
        <li>Personal details such as your name, email, phone number, and address collected during checkout or account registration</li>
        <li>Browsing data including your IP address, browser type, and pages visited</li>
    </ul>

    <h5 class="mt-4">2. How We Use Your Information</h5>
    <ul>
        <li>To process and fulfill your orders</li>
        <li>To send you order updates, special offers, and promotional content</li>
        <li>To enhance your shopping experience through personalized services</li>
    </ul>

    <h5 class="mt-4">3. Data Security</h5>
    <p>
        We use industry-standard encryption and security protocols to protect your data.
        Your personal information is stored securely and is never sold or shared without your explicit consent.
    </p>

    <h5 class="mt-4">4. Your Rights</h5>
    <p>
        You have the right to access, update, or delete your personal information at any time.
        To exercise these rights, contact our Privacy Team at <strong>privacy@shopsmart.com</strong>.
    </p>

    <p class="mt-4"><em>Last Updated: June 2025</em></p>
</div>
