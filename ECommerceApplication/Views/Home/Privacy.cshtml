@{
    ViewData["Title"] = "Privacy Policy";
}
<link rel="stylesheet" href="~/css/info-pages.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4">Privacy Policy</h2>
    <p>
        At ShopSmart, we value your privacy and are committed to protecting your personal information. 
        This Privacy Policy outlines how we collect, use, and safeguard your data when you visit or 
        make a purchase from our website.
    </p>

    <h5 class="mt-4">1. Information We Collect</h5>
    <ul>
        <li>Personal details like name, email, phone, and address during checkout or registration</li>
        <li>Browsing data such as IP address, device type, and pages visited</li>
    </ul>

    <h5 class="mt-4">2. How We Use Your Information</h5>
    <ul>
        <li>To fulfill your orders and deliver products</li>
        <li>To send updates, offers, and promotional content</li>
        <li>To improve our website and services</li>
    </ul>

    <h5 class="mt-4">3. Data Security</h5>
    <p>
        We implement security measures to maintain the safety of your personal information. Your data is 
        encrypted and never shared with third parties without your consent.
    </p>

    <h5 class="mt-4">4. Your Rights</h5>
    <p>
        You have the right to request access to, update, or delete your personal information. For any queries, 
        contact us at <strong>privacy@shopsmart.com</strong>.
    </p>

    <p class="mt-4">Updated: June 2025</p>
</div>
